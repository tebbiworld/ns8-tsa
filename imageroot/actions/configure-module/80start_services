# Enable and (re)start the timestamp server. The certificate material is already
# in place (generated by 20generate_certificate) and readable by UID 65532.

import subprocess

subprocess.run(["systemctl", "--user", "enable", "tsa.service"], check=True)
subprocess.run(["systemctl", "--user", "restart", "tsa.service"], check=True)
